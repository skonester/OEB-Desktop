<?xml version="1.0" encoding="utf-8" standalone="no"?>
<Project ToolsVersion="14.0" xmlns="http://schemas.microsoft.com/developer/msbuild/2003">
  <PropertyGroup Condition=" '$(ExcludeRestorePackageImports)' != 'true' ">
    <RestoreSuccess Condition=" '$(RestoreSuccess)' == '' ">True</RestoreSuccess>
    <RestoreTool Condition=" '$(RestoreTool)' == '' ">NuGet</RestoreTool>
    <ProjectAssetsFile Condition=" '$(ProjectAssetsFile)' == '' ">$(MSBuildThisFileDirectory)project.assets.json</ProjectAssetsFile>
    <NuGetPackageRoot Condition=" '$(NuGetPackageRoot)' == '' ">$(UserProfile)\.nuget\packages\</NuGetPackageRoot>
    <NuGetPackageFolders Condition=" '$(NuGetPackageFolders)' == '' ">C:\Users\admin\.nuget\packages\</NuGetPackageFolders>
    <NuGetProjectStyle Condition=" '$(NuGetProjectStyle)' == '' ">PackageReference</NuGetProjectStyle>
    <NuGetToolVersion Condition=" '$(NuGetToolVersion)' == '' ">7.0.0</NuGetToolVersion>
  </PropertyGroup>
  <ItemGroup Condition=" '$(ExcludeRestorePackageImports)' != 'true' ">
    <SourceRoot Include="C:\Users\admin\.nuget\packages\" />
  </ItemGroup>
  <ImportGroup Condition=" '$(ExcludeRestorePackageImports)' != 'true' ">
    <Import Project="$(NuGetPackageRoot)microsoft.cognitiveservices.speech\1.50.0\build\Microsoft.CognitiveServices.Speech.props" Condition="Exists('$(NuGetPackageRoot)microsoft.cognitiveservices.speech\1.50.0\build\Microsoft.CognitiveServices.Speech.props')" />
  </ImportGroup>
  <PropertyGroup Condition=" '$(ExcludeRestorePackageImports)' != 'true' ">
    <PkgSystem_Speech Condition=" '$(PkgSystem_Speech)' == '' ">C:\Users\admin\.nuget\packages\system.speech\10.0.8</PkgSystem_Speech>
    <PkgNAudio Condition=" '$(PkgNAudio)' == '' ">C:\Users\admin\.nuget\packages\naudio\2.2.1</PkgNAudio>
    <PkgMicrosoft_Data_Sqlite Condition=" '$(PkgMicrosoft_Data_Sqlite)' == '' ">C:\Users\admin\.nuget\packages\microsoft.data.sqlite\10.0.8</PkgMicrosoft_Data_Sqlite>
    <PkgMicrosoft_CognitiveServices_Speech Condition=" '$(PkgMicrosoft_CognitiveServices_Speech)' == '' ">C:\Users\admin\.nuget\packages\microsoft.cognitiveservices.speech\1.50.0</PkgMicrosoft_CognitiveServices_Speech>
    <PkgLucene_Net Condition=" '$(PkgLucene_Net)' == '' ">C:\Users\admin\.nuget\packages\lucene.net\4.8.0-beta00017</PkgLucene_Net>
    <PkgLucene_Net_Analysis_Common Condition=" '$(PkgLucene_Net_Analysis_Common)' == '' ">C:\Users\admin\.nuget\packages\lucene.net.analysis.common\4.8.0-beta00017</PkgLucene_Net_Analysis_Common>
    <PkgKrypton_Toolkit Condition=" '$(PkgKrypton_Toolkit)' == '' ">C:\Users\admin\.nuget\packages\krypton.toolkit\105.26.4.110</PkgKrypton_Toolkit>
    <PkgKokoroSharp Condition=" '$(PkgKokoroSharp)' == '' ">C:\Users\admin\.nuget\packages\kokorosharp\0.6.7</PkgKokoroSharp>
    <PkgKokoroSharp_CPU Condition=" '$(PkgKokoroSharp_CPU)' == '' ">C:\Users\admin\.nuget\packages\kokorosharp.cpu\0.6.7</PkgKokoroSharp_CPU>
    <PkgFSharp_Core Condition=" '$(PkgFSharp_Core)' == '' ">C:\Users\admin\.nuget\packages\fsharp.core\10.1.201</PkgFSharp_Core>
  </PropertyGroup>
</Project>